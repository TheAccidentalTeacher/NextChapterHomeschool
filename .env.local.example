# ============================================
# ClassCiv Environment Variables
# Copy this file to .env.local and fill in values
# ============================================

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# --- Clerk ---
# Get these from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here

# Clerk routing (do not change these)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# --- Claude AI (for narration — optional, future feature) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Debug ---
# Set to "true" to enable F12 console debug toolkit
# Type classciv.debug.help() in browser console for commands
NEXT_PUBLIC_DEBUG=true

# --- HeyGen (for NPC video — optional, future feature) ---
HEYGEN_API_KEY=your-heygen-api-key-here
